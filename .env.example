# Telegram API credentials (получить на https://my.telegram.org/apps)
API_ID=your_api_id_here
API_HASH=your_api_hash_here
PHONE=+79991234567

# Bot Token (получить от @BotFather)
BOT_TOKEN=your_bot_token_here

# Ваш ChatID для уведомлений (целое число! получить от @userinfobot)
YOUR_CHAT_ID=your_chat_id_here

# Админы, которые могут управлять ботом (ID через запятую)
ADMIN_IDS=123456789,987654321

# Прокси по умолчанию (опционально)
# DEFAULT_PROXY_HOST=
# DEFAULT_PROXY_PORT=
# DEFAULT_PROXY_SECRET=

# Настройки
MESSAGES_LIMIT=20
CHECK_TIMEOUT=10
PING_THRESHOLD=250
