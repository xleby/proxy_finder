# Telegram API Credentials
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# Your phone number for account login (format: +79991234567)
PHONE=

# Bot token from @BotFather (optional, for bot features)
BOT_TOKEN=

# Your Chat ID for receiving notifications (get from @userinfobot)
YOUR_CHAT_ID=

# Default proxy for initial connection (optional)
# Leave empty if not needed
DEFAULT_PROXY_HOST=
DEFAULT_PROXY_PORT=
DEFAULT_PROXY_SECRET=

# Settings
MESSAGES_LIMIT=20
CHECK_TIMEOUT=30
CHANNEL_USERNAME=@ProxyMTProto

# GitHub Raw URLs for proxy scraping (comma-separated)
# GITHUB_SOURCES=https://raw.githubusercontent.com/user/repo/main/file.md
